# GSimulator 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# --- LLM 配置 (OpenAI-compatible Chat Completions API) ---
LLM_BASE_URL=https://your-openai-compatible-endpoint/v1
LLM_API_KEY=replace-me
LLM_MODEL=deepseek-v4-pro
LLM_TEMPERATURE=0.3
LLM_TIMEOUT_SECONDS=120

# --- ChromaDB 配置 ---
CHROMA_BASE_URL=http://localhost:8000
CHROMA_ENABLED=false

# --- 联网研究配置 ---
WEB_RESEARCH_ENABLED=false
WEB_RESEARCH_TIMEOUT_SECONDS=30
WEB_RESEARCH_USER_AGENT=GSimulator/0.1.0 (research-bot)

# --- 应用配置 ---
GSIM_DATA_DIR=data
GSIM_IMPORT_DIR=import
GSIM_OUTPUT_DIR=data/outputs
GSIM_LOG_DIR=data/logs
